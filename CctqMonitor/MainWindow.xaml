<Window x:Class="CctqMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CCTQ Monitor"
        SizeToContent="WidthAndHeight"
        MinWidth="198"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
  <Border x:Name="Shell"
          Background="{StaticResource CanvasBrush}"
          BorderBrush="{StaticResource HairlineBrush}"
          BorderThickness="1"
          CornerRadius="18"
          Padding="17"
          MouseLeftButtonDown="Shell_OnMouseLeftButtonDown"
          MouseRightButtonUp="Shell_OnMouseRightButtonUp">
    <Border.ContextMenu>
      <ContextMenu>
        <MenuItem Header="刷新" Click="RefreshMenuItem_OnClick"/>
        <Separator/>
        <MenuItem x:Name="LockMenuItem" Header="锁定位置" IsCheckable="True" Click="LockMenuItem_OnClick"/>
        <MenuItem x:Name="TopmostMenuItem" Header="置顶" IsCheckable="True" Click="TopmostMenuItem_OnClick"/>
        <Separator/>
        <MenuItem Header="设置" Click="SettingsMenuItem_OnClick"/>
        <MenuItem Header="退出" Click="ExitMenuItem_OnClick"/>
      </ContextMenu>
    </Border.ContextMenu>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" MinWidth="76"/>
        <ColumnDefinition Width="14"/>
        <ColumnDefinition Width="Auto" MinWidth="70"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <Ellipse x:Name="ConnectionDot"
                 Width="10"
                 Height="10"
                 Fill="#A1A1A6"
                 VerticalAlignment="Center"
                 Margin="0,0,8,0"/>
        <TextBlock x:Name="LatencyText"
                   Text=""
                   Foreground="{StaticResource InkBrush}"
                   FontFamily="Microsoft YaHei UI, Segoe UI, system-ui"
                   FontSize="12"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>
        <TextBlock x:Name="StatusText"
                   Text="需要配置"
                   Foreground="{StaticResource MutedInkBrush}"
                   FontFamily="Microsoft YaHei UI, Segoe UI, system-ui"
                   FontSize="12"
                   FontWeight="Regular"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <TextBlock Grid.Row="0"
                 Grid.Column="2"
                 Text="CCTQ"
                 Foreground="{StaticResource InkBrush}"
                 FontFamily="Microsoft YaHei UI, Segoe UI, system-ui"
                 FontSize="12"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Right"/>

      <StackPanel Grid.Row="1" Grid.Column="0" MinWidth="76" Margin="0,14,0,0">
        <TextBlock Text="总余额"
                   Foreground="{StaticResource MutedInkBrush}"
                   FontFamily="Microsoft YaHei UI, Segoe UI, system-ui"
                   FontSize="12"/>
        <TextBlock x:Name="BalanceText"
                   Text="0.00"
                   Foreground="{StaticResource InkBrush}"
                   FontFamily="Microsoft YaHei UI, Segoe UI, system-ui"
                   FontSize="25"
                   FontWeight="SemiBold"
                   LineHeight="34"
                   Margin="0,2,0,0"/>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Grid.Column="2"
                  MinWidth="70"
                  Margin="0,14,0,0"
                  HorizontalAlignment="Right">
        <TextBlock Text="今日消耗"
                   Foreground="{StaticResource MutedInkBrush}"
                   FontFamily="Microsoft YaHei UI, Segoe UI, system-ui"
                   FontSize="12"
                   HorizontalAlignment="Right"/>
        <TextBlock x:Name="TodayUsageText"
                   Text="0.00"
                   Foreground="{StaticResource InkBrush}"
                   FontFamily="Microsoft YaHei UI, Segoe UI, system-ui"
                   FontSize="25"
                   FontWeight="SemiBold"
                   LineHeight="34"
                   Margin="0,2,0,0"
                   HorizontalAlignment="Right"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
