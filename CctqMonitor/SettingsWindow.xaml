<Window x:Class="CctqMonitor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CCTQ Monitor 设置"
        Width="360"
        Height="292"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent">
  <Window.Resources>
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
      <Setter Property="FontFamily" Value="Segoe UI, system-ui"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="TextInputStyle" TargetType="TextBox">
      <Setter Property="Height" Value="40"/>
      <Setter Property="Padding" Value="13,0"/>
      <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, system-ui"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
      <Setter Property="Background" Value="{StaticResource CanvasBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ScrollViewer x:Name="PART_ContentHost"
                            VerticalAlignment="Center"
                            Margin="0"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PasswordInputStyle" TargetType="PasswordBox">
      <Setter Property="Height" Value="40"/>
      <Setter Property="Padding" Value="13,0"/>
      <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, system-ui"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
      <Setter Property="Background" Value="{StaticResource CanvasBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource HairlineBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="PasswordBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ScrollViewer x:Name="PART_ContentHost"
                            VerticalAlignment="Center"
                            Margin="0"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Border Background="{StaticResource ParchmentBrush}"
          BorderBrush="{StaticResource HairlineBrush}"
          BorderThickness="1"
          CornerRadius="18"
          Padding="24"
          MouseLeftButtonDown="Shell_OnMouseLeftButtonDown">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0">
        <TextBlock Text="设置"
                   Foreground="{StaticResource InkBrush}"
                   FontFamily="Segoe UI, system-ui"
                   FontSize="17"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
        <Button Content="×"
                Width="32"
                Height="32"
                DockPanel.Dock="Right"
                HorizontalAlignment="Right"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{StaticResource MutedInkBrush}"
                FontSize="20"
                Click="CancelButton_OnClick"/>
      </DockPanel>

      <StackPanel Grid.Row="1" Margin="0,18,0,0">
        <WrapPanel Margin="0,0,0,6">
          <TextBlock Text="系统访问令牌" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
          <TextBlock Text="个人设置-安全设置-系统访问令牌"
                     Foreground="{StaticResource MutedInkBrush}"
                     FontFamily="Microsoft YaHei UI, Segoe UI, system-ui"
                     FontSize="12"
                     VerticalAlignment="Center"/>
        </WrapPanel>
        <PasswordBox x:Name="TokenBox" Style="{StaticResource PasswordInputStyle}"/>

        <WrapPanel Margin="0,14,0,6">
          <TextBlock Text="用户 ID" Style="{StaticResource FieldLabelStyle}" Margin="0,0,6,0"/>
          <TextBlock Text="个人设置-ID"
                     Foreground="{StaticResource MutedInkBrush}"
                     FontFamily="Microsoft YaHei UI, Segoe UI, system-ui"
                     FontSize="12"
                     VerticalAlignment="Center"/>
        </WrapPanel>
        <TextBox x:Name="UserIdBox" Style="{StaticResource TextInputStyle}"/>

        <TextBlock x:Name="ErrorText"
                   Foreground="#FF3B30"
                   FontFamily="Segoe UI, system-ui"
                   FontSize="12"
                   Margin="0,10,0,0"/>
      </StackPanel>

      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="取消"
                Width="84"
                Height="36"
                Margin="0,0,10,0"
                Background="{StaticResource CanvasBrush}"
                BorderBrush="{StaticResource HairlineBrush}"
                Click="CancelButton_OnClick"/>
        <Button Content="保存"
                Width="84"
                Height="36"
                Foreground="White"
                Background="{StaticResource ActionBlueBrush}"
                BorderBrush="{StaticResource ActionBlueBrush}"
                Click="SaveButton_OnClick"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
